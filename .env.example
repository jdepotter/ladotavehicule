# Plate Recognizer — primary vehicle/plate identification
# Free: 2,500 lookups/month — https://platerecognizer.com/
PLATE_RECOGNIZER_TOKEN=

# Google Gemini — vehicle color/make/style
# Free: 1,000 req/day (flash-lite) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Mapbox — cross-street detection (server) + interactive map (client)
# Free: 200k vector-tile requests/mo + 50k map loads/mo
# https://account.mapbox.com/access-tokens/
# Same token can be used for both; NEXT_PUBLIC_ prefix exposes it to the browser.
MAPBOX_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=

# Supabase — event logging (optional; logs silently no-op if unset)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
